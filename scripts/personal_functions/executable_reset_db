#!/bin/bash
set -e

DB_CLEAR_PATH="$HOME/Documents/banco_limpo"
DB_OUTPUT_PATH="$HOME/.config/.db_output"

SERVICES=("firebird5.0-superserver.service" "firebird3.0-superserver.service")

ACTIVE_SERVICE=""
for svc in "${SERVICES[@]}"; do
    if systemctl is-active --quiet "$svc"; then
        ACTIVE_SERVICE="$svc"
        break
    fi
done

if [[ -z "$ACTIVE_SERVICE" ]]; then
    echo "Nenhuma instância do Firebird está ativa no momento. Abortando."
    exit 1
fi

echo "Instância ativa detectada: $ACTIVE_SERVICE"
echo "Parando..."
sudo systemctl stop "$ACTIVE_SERVICE"

mkdir -p "$DB_OUTPUT_PATH"
rm -f "$DB_OUTPUT_PATH"/* 2>/dev/null

cp -rfp "$DB_CLEAR_PATH"/* "$DB_OUTPUT_PATH"

echo "Reiniciando $ACTIVE_SERVICE..."
sudo systemctl start "$ACTIVE_SERVICE"

echo "---"
echo "Processo finalizado em $DB_OUTPUT_PATH"
echo "Arquivos criados:"
for file in "$DB_OUTPUT_PATH"/*; do
    echo "$file"
done