#!/bin/bash
# /usr/local/bin/activate_fb5
set -euo pipefail

FB_HOME="/opt/firebird5.0"
LIB="$FB_HOME/lib"
OWN_SERVICE="firebird5.0-superserver.service"
OTHER_SERVICE="firebird3.0-superserver.service"

echo "Parando instância 3.0 (se estiver rodando)..."
sudo systemctl stop "$OTHER_SERVICE" 2>/dev/null || true

echo "Ajustando links de libfbclient para 5.0..."
sudo find /usr/lib -maxdepth 1 -name 'libfbclient.so*' -exec rm -f {} \;
for f in "$LIB"/libfbclient.so*; do
    name=$(basename "$f")
    sudo ln -sf "$f" "/usr/lib/$name"
done
sudo ldconfig

echo "Subindo Firebird 5.0..."
sudo systemctl start "$OWN_SERVICE"
sudo systemctl status "$OWN_SERVICE" --no-pager

echo "Firebird ativo: 5.0 ($FB_HOME) — porta 3050"